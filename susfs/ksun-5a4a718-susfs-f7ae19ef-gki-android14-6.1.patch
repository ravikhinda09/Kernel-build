+			case CMD_SUSFS_SHOW_VERSION:
+				susfs_show_version(arg);
+				return 0;
+			default:
+				return -EINVAL;
+		}
+	}
+
+	// Handle standard Toolkit MAGICS via unified handler
+	return ksu_handle_toolkit_reboot(magic2, cmd, *arg);
